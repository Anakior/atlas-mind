__pycache__/
*.pyc
node_modules/
dist/
.venv/
*.egg-info/
# setuptools build artifact (repo root only) — anchored so it does NOT match the
# src/build/ engine package, which IS versioned.
/build/
content/
.notes/
.atlas/
# Throwaway mind served by `atlas dev` / docker-compose.dev.yml (accounts + edits).
.dev-mind/

# Exception: the bundled demo mind IS versioned (source of the public GitHub
# Pages demo built into docs/). Re-include its content/ despite the rule above.
!examples/demo-mind/content/
!examples/demo-mind/content/**
# …and its example annotations (.notes sidecars), so the offline demo ships with
# a couple of highlighted passages baked in.
!examples/demo-mind/.notes/
!examples/demo-mind/.notes/**
# Exception: the contradiction-detection golden corpus is a test fixture read as
# ground truth — versioned despite the content/ rule above.
!tests/fixtures/contradictions_kb/content/
!tests/fixtures/contradictions_kb/content/**
# Throwaway mind + artifacts for the Playwright e2e goldens (src/web/ts/e2e).
.e2e-mind/
src/web/ts/e2e/.auth/
src/web/ts/e2e/.artifacts/
src/web/ts/test-results/
src/web/ts/playwright-report/

key.pem
